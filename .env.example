# AWS Configuration
# Your AWS region where resources are deployed
AWS_REGION=us-east-1

# AWS credentials for accessing Bedrock and other AWS services
# Replace with your actual AWS Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here

# Replace with your actual AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# Amazon Bedrock Inference Profile ARNs
# These are used for AI-powered features via AWS Bedrock

# Primary Bedrock inference profile ARN
# Format: arn:aws:bedrock:REGION:ACCOUNT_ID:application-inference-profile/PROFILE_ID
BEDROCK_INFERENCE_PROFILE_ARN=arn:aws:bedrock:us-east-1:123456789012:application-inference-profile/your_profile_id

# Bedrock Haiku model inference profile ARN (for faster, lighter AI tasks)
# Format: arn:aws:bedrock:REGION:ACCOUNT_ID:application-inference-profile/PROFILE_ID
BEDROCK_HAIKU_INFERENCE_PROFILE_ARN=arn:aws:bedrock:us-east-1:123456789012:application-inference-profile/your_haiku_profile_id